<svg width="1024" height="1024" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg">
  <!-- Lens Logo - Dark Mode (White BG, Colored Ring) -->
  <defs>
    <linearGradient id="ringGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2563EB;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#7C3AED;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- White Background -->
  <rect width="1024" height="1024" fill="white"/>
  
  <!-- Colored ring -->
  <circle cx="512" cy="512" r="280" fill="none" stroke="url(#ringGradient)" stroke-width="96" stroke-linecap="round"/>
  
  <!-- Offset circle (subtle gradient) -->
  <circle cx="620" cy="400" r="80" fill="url(#ringGradient)" opacity="0.25"/>
</svg>
